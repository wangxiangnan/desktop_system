# 通用基础配置（所有环境共享）
# 各环境配置文件会覆盖这里的值

# 应用基本配置
APP_NAME=看个比赛票务管理平台
APP_VERSION=1.0.0

# 功能开关
ENABLE_ANALYTICS=false
ENABLE_CRASH_REPORTING=false
ENABLE_LOGGING=true

# 超时配置（毫秒）
RECEIVE_TIMEOUT=30000
CONNECT_TIMEOUT=10000

# 分页配置
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# 缓存配置
CACHE_DURATION=3600
ENABLE_CACHE=true

# 文件上传配置
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx
